# Copy to .env.local and fill in. Never commit real values.

# ---- App ----
# Production: set to the deployed URL (e.g. https://your-app.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Supabase (project: ddybrijphsummtkndvro) ----
NEXT_PUBLIC_SUPABASE_URL=https://ddybrijphsummtkndvro.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # SERVER ONLY, never expose to the browser

# ---- Admin allowlist (comma-separated emails) ----
ADMIN_EMAILS=

# ---- Anthropic ----
ANTHROPIC_API_KEY=
ATLAS_AI_MODEL=claude-sonnet-4-6

# ---- Stripe (TEST mode only) ----
STRIPE_SECRET_KEY=                  # sk_test_...
STRIPE_WEBHOOK_SECRET=              # whsec_... (from the Stripe webhook endpoint)
STRIPE_PRICE_SPRINT=                # optional; blank = inline $149 one-time
STRIPE_PRICE_CONTINUOUS=            # optional; blank = inline $39/mo

# ---- Transactional email (optional) ----
# Used for the "your diagnosis is ready" notification sent after admin approval.
# If RESEND_API_KEY is blank, emails are logged to the server console, not sent.
RESEND_API_KEY=                     # re_... (https://resend.com)
RESEND_FROM=Sapient Atlas <onboarding@resend.dev>  # verified sender once live
